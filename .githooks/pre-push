#!/bin/bash
# Chatty Critter — Pre-push regression gate
# Install: bash tests/install-hooks.sh

REPO_ROOT="$(git rev-parse --show-toplevel)"
TEST_FILE="$REPO_ROOT/tests/regression.html"

echo ""
echo "╔══════════════════════════════════════════╗"
echo "║   🧪 Chatty Critter — Regression Gate    ║"
echo "╚══════════════════════════════════════════╝"
echo ""
echo "Before pushing, please run the regression test suite and"
echo "confirm ALL tests pass."
echo ""
echo "Opening test suite in browser..."

# Open the test file
if command -v open &>/dev/null; then
  open "$TEST_FILE"
elif command -v xdg-open &>/dev/null; then
  xdg-open "$TEST_FILE"
elif command -v start &>/dev/null; then
  start "$TEST_FILE"
else
  echo "Could not open browser automatically."
  echo "Please open manually: $TEST_FILE"
fi

echo ""
echo "Have ALL tests passed? (y = push / n = cancel)"
read -r answer </dev/tty

if [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
  echo "✅ Tests confirmed. Pushing..."
  echo ""
  exit 0
else
  echo ""
  echo "❌ Push cancelled. Fix failing tests before pushing."
  echo ""
  exit 1
fi
